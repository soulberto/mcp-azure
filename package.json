{
  "name": "@slorenzot/mcp-azure",
  "version": "2.7.4",
  "description": "Servidor MCP para Azure DevOps con manejo robusto de errores, soporte .mcp.json y manejo de concurrencia en adjuntos",
  "keywords": [
    "mcp",
    "azure",
    "model-context-protocol",
    "azure-devops",
    "error-handling",
    "mcp-json"
  ],
  "license": "MIT",
  "author": "Soulberto Lorenzo",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "mcp-azure": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "release:check": "npm run build && npm pack --dry-run --cache /private/tmp/mcp-azure-npm-cache",
    "release:version:patch": "npm version patch --no-git-tag-version && npm install --package-lock-only",
    "release:version:minor": "npm version minor --no-git-tag-version && npm install --package-lock-only",
    "release:version:major": "npm version major --no-git-tag-version && npm install --package-lock-only",
    "release:publish": "npm publish --access public --cache /private/tmp/mcp-azure-npm-cache"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "azure-devops-node-api": "^14.1.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^5.9.3"
  }
}
